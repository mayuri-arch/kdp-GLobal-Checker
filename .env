# Copy this file to ".env" and fill in.

# Flask session signing key (generate: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=change-me-to-a-random-64-char-hex

# SQLite database file path
KDP_DB=kdp_checker.db

# Scheduler — set to 1 to enable daily background monitoring
ENABLE_SCHEDULER=0
SCHEDULER_HOUR=7
SCHEDULER_MINUTE=0

# Stripe — required for paid plans. Leave blank for local dev.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# Optional proxy for residential IP rotation (recommended for production)
# HTTP_PROXY=http://user:pass@gate.residential.example:8000
